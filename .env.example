# ============================================================
# Beispiel-Konfiguration – Faszienbehandlung.jetzt
# Kopieren als .env (Entwicklung) oder .env.production (Server)
# ============================================================

# Server
HOST=127.0.0.1
PORT=8080
BASE_URL=https://faszienbehandlung.jetzt

# Datenbank (Pfad zur SQLite-Datei)
DATABASE_URL=data/faszien.db

# JWT – zufälliger 64-Zeichen-String, niemals ändern solange aktive Sessions existieren
# Generieren: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_64_char_hex_string
JWT_EXPIRY_HOURS=168

# Admin-Konto (wird beim ersten Start angelegt; danach nur noch Passwortänderung aktiv)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_to_a_secure_password

# SMTP (E-Mail-Versand für Buchungsbestätigungen, Erinnerungen, Warteliste etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=your@email.com
SMTP_FROM_NAME=Faszienbehandlung | Thilo Seifried
